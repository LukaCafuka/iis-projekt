@page "/"
@attribute [AllowAnonymous]

<PageTitle>IIS Interop</PageTitle>

<h1>Interoperability demo</h1>
<AuthorizeView>
    <Authorized>
        <p>Signed in as <strong>@context.User.Identity?.Name</strong>.</p>
    </Authorized>
    <NotAuthorized>
        <p><a href="login">Log in</a> or <a href="register">register</a> (seed users: reader@iis.local / Reader123!, full@iis.local / Full123!).</p>
    </NotAuthorized>
</AuthorizeView>
