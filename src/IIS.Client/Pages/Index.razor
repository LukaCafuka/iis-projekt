@page "/"
@attribute [AllowAnonymous]

<PageTitle>IIS Interop</PageTitle>

<h1>Interoperability demo</h1>
<p class="lead">College project: REST (import + JWT CRUD), SOAP (MockAPI + XPath), XSD validation, gRPC (DHMZ weather), GraphQL, and a public/custom API switch.</p>
<AuthorizeView>
    <Authorized>
        <p>Signed in as <strong>@context.User.Identity?.Name</strong>. Use the navigation menu for each integration.</p>
    </Authorized>
    <NotAuthorized>
        <p><a href="login">Log in</a> or <a href="register">register</a> (seed users: reader@iis.local / Reader123!, full@iis.local / Full123!).</p>
    </NotAuthorized>
</AuthorizeView>
