@page "/validation"
@page "/xml-validation"
@attribute [Authorize(Roles = "Full")]
@inject ApiClientWithAuthFactory ApiClientFactory

<PageTitle>Validation</PageTitle>

<h1>Validate XML / JSON</h1>
<p>POSTs raw payloads to <code>api/validation/xml</code> and <code>api/validation/json</code>.</p>

<div class="row">
    <div class="col-md-6">
        <h3>XML (XSD)</h3>
        <textarea class="form-control font-monospace" rows="10" @bind="_xml"></textarea>
        <button class="btn btn-primary mt-2" @onclick="ValidateXml">Validate XML</button>
        @if (!string.IsNullOrEmpty(_xmlResult))
        {
            <pre class="mt-3 small response-output">@_xmlResult</pre>
        }
    </div>

    <div class="col-md-6 mt-4 mt-md-0">
        <h3>JSON (Schema)</h3>
        <textarea class="form-control font-monospace" rows="10" @bind="_json"></textarea>
        <button class="btn btn-primary mt-2" @onclick="ValidateJson">Validate JSON</button>
        @if (!string.IsNullOrEmpty(_jsonResult))
        {
            <pre class="mt-3 small response-output">@_jsonResult</pre>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(_generalError))
{
    <pre class="mt-3 small response-output text-danger">@_generalError</pre>
}

@code {
        private string _xml = """
<Tasks>
    <Task>
        <name>Sample task</name>
        <description>Sample description</description>
        <completed>false</completed>
    </Task>
</Tasks>
""";
        private string _json = """
{
    "name": "Sample task",
    "description": "Sample description",
    "completed": false
}
""";
    private string? _xmlResult;
    private string? _jsonResult;
    private string? _generalError;

    private async Task ValidateXml()
    {
        _generalError = null;
        _xmlResult = null;
        try
        {
            var client = ApiClientFactory.CreateClient();
            using var content = new StringContent(_xml, System.Text.Encoding.UTF8, "application/xml");
            var resp = await client.PostAsync("api/validation/xml", content);
            var body = await resp.Content.ReadAsStringAsync();
            _xmlResult = ResponseFormatter.FormatHttpResponse(resp, body);
        }
        catch (Exception ex)
        {
            _generalError = ResponseFormatter.FormatException(ex);
        }
    }

    private async Task ValidateJson()
    {
        _generalError = null;
        _jsonResult = null;
        try
        {
            var client = ApiClientFactory.CreateClient();
            using var content = new StringContent(_json, System.Text.Encoding.UTF8, "application/json");
            var resp = await client.PostAsync("api/validation/json", content);
            var body = await resp.Content.ReadAsStringAsync();
            _jsonResult = ResponseFormatter.FormatHttpResponse(resp, body);
        }
        catch (Exception ex)
        {
            _generalError = ResponseFormatter.FormatException(ex);
        }
    }
}
